/*
   Commands to run:
   actsim -Wlang_subst:off testbench_ann_throughput.act test_ann_throughput
*/

import "../../src/ann_components.act";

defproc ann_binary_stream_check (chan!(int<8>) IN1; chan!(int<8>) IN2; chan?(int<8>) OUT)
{
  int<8> y;

  chp {
    /* two consecutive XOR truth-table sweeps, no reset */
    IN1!0; IN2!0; OUT?y; assert(y = 0);
    IN1!0; IN2!1; OUT?y; assert(y = 1);
    IN1!1; IN2!0; OUT?y; assert(y = 1);
    IN1!1; IN2!1; OUT?y; assert(y = 0);

    IN1!1; IN2!0; OUT?y; assert(y = 1);
    IN1!0; IN2!1; OUT?y; assert(y = 1);
    IN1!1; IN2!1; OUT?y; assert(y = 0);
    IN1!0; IN2!0; OUT?y; assert(y = 0)
  }
}

defproc ann_sigmoid_stream_check (chan!(int<8>) IN1; chan!(int<8>) IN2; chan?(int<8>) OUT)
{
  int<8> y;

  chp {
    /* two consecutive XOR truth-table sweeps, no reset */
    IN1!0; IN2!0; OUT?y; assert(y = 0);
    IN1!0; IN2!1; OUT?y; assert(y = 4);
    IN1!1; IN2!0; OUT?y; assert(y = 4);
    IN1!1; IN2!1; OUT?y; assert(y = 0);

    IN1!1; IN2!0; OUT?y; assert(y = 4);
    IN1!0; IN2!1; OUT?y; assert(y = 4);
    IN1!1; IN2!1; OUT?y; assert(y = 0);
    IN1!0; IN2!0; OUT?y; assert(y = 0)
  }
}

export defproc test_ann_throughput ()
{
  ANNStep                 step_dut;
  ANNReLU                 relu_dut;
  ANNSigmoid              sigmoid_dut;
  ann_binary_stream_check step_check(step_dut.IN1, step_dut.IN2, step_dut.OUT);
  ann_binary_stream_check relu_check(relu_dut.IN1, relu_dut.IN2, relu_dut.OUT);
  ann_sigmoid_stream_check sigmoid_check(sigmoid_dut.IN1, sigmoid_dut.IN2, sigmoid_dut.OUT);
}
